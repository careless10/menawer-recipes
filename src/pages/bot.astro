---
import Layout from '../layouts/Layout.astro';
// Inline the recipe markdown at build-time so we can both display + copy it.
import recipeRaw from '../content/build-my-chatbot.md?raw';

const recipeLength = recipeRaw.length;
---

<Layout
  title="شات بوت لشغلك · Business Chatbot — Menawer Recipes"
  description="انسخ الوصفة، الصقها في كلود، احصل على شات بوت لـبزنسك بأقل من ١٥ دقيقة. RAG + Tool calling عبر OpenRouter. / Paste this recipe into Claude and ship a working business chatbot in 15 minutes."
  ogPath="/bot"
  noindex
>

  <!-- ── Hero ── -->
  <section class="mx-auto max-w-4xl px-5 sm:px-8 pt-14 sm:pt-24 pb-12">
    <div>
      <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] font-semibold text-claude-orange">
        <span class="w-1.5 h-1.5 rounded-full bg-claude-orange"></span>
        Recipe #1 · From @eng_menawer
      </span>

      <!-- Arabic title (primary) -->
      <h1 dir="rtl" class="mt-6 font-cairo font-extrabold tracking-tight leading-[1.15] text-5xl sm:text-7xl text-right">
        سوّ <span class="text-claude-orange">شات بوت</span> لـبزنسك
      </h1>

      <!-- English title (secondary) -->
      <h2 class="mt-3 text-3xl sm:text-5xl font-extrabold tracking-tight leading-[1.04] text-ink/85">
        Build a chatbot
        <br class="hidden sm:block" />
        for <span class="text-claude-orange">your business.</span>
      </h2>

      <!-- Arabic description -->
      <p dir="rtl" class="mt-8 font-cairo text-lg sm:text-xl text-ink/75 leading-relaxed text-right">
        انسخ الوصفة وحطّها في كلود. جاوب على ٤ أسئلة قصيرة. شات بوت شغّال لـبزنسك بأقل من ١٥ دقيقة —
        <strong class="text-ink">RAG + Tool calling عبر OpenRouter، بدون لف ودوران.</strong>
      </p>

      <!-- English description -->
      <p class="mt-3 text-base sm:text-lg text-ink/60 leading-relaxed max-w-2xl">
        Paste this recipe into Claude. Answer 4 short questions. Get a working chatbot
        tailored to your business in under 15 minutes —
        <strong class="text-ink/85">RAG + Tool calling, OpenRouter, no fluff</strong>.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:items-center">
        <button
          id="copy-btn"
          class="group inline-flex items-center justify-center gap-3 bg-claude-orange text-cream px-7 py-4 rounded-full font-semibold text-base hover:bg-ink transition-colors cursor-pointer"
          aria-label="Copy the recipe / انسخ الوصفة"
        >
          <svg class="copy-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="check-icon hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"></path>
          </svg>
          <span class="copy-label">انسخ الوصفة · Copy the recipe</span>
        </button>
      </div>

      <p class="mt-5 text-xs text-ink/40 uppercase tracking-wider">
        {recipeLength.toLocaleString()} characters · paste into <a href="https://claude.ai" target="_blank" rel="noopener" class="text-ink/55 hover:text-claude-orange underline underline-offset-2">claude.ai</a>
      </p>
    </div>
  </section>

  <!-- ── How to use ── -->
  <section class="mx-auto max-w-4xl px-5 sm:px-8 pb-16">
    <div class="mb-6 flex items-baseline justify-between flex-wrap gap-2">
      <h2 dir="rtl" class="font-cairo text-2xl font-bold text-ink">كيف تشتغل</h2>
      <span class="text-sm uppercase tracking-[0.18em] font-semibold text-ink/40">How it works</span>
    </div>

    <ol class="grid sm:grid-cols-2 gap-4">
      <li class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <div class="flex items-baseline gap-3 mb-2">
          <span class="font-extrabold text-claude-orange text-2xl">١ · 1</span>
          <div>
            <h3 dir="rtl" class="font-cairo font-bold text-lg text-right">افتح كلود</h3>
            <h3 class="font-semibold text-base text-ink/70">Open Claude</h3>
          </div>
        </div>
        <p dir="rtl" class="font-cairo text-ink/75 text-sm leading-relaxed text-right mt-2">
          <a href="https://claude.ai" target="_blank" rel="noopener" class="text-ink/85 underline underline-offset-2 decoration-claude-orange/40 hover:text-claude-orange">claude.ai</a> (الأسهل، من المتصفح)
          أو <a href="https://www.anthropic.com/claude-code" target="_blank" rel="noopener" class="text-ink/85 underline underline-offset-2 decoration-claude-orange/40 hover:text-claude-orange">Claude Code</a> إذا عندك.
        </p>
        <p class="text-ink/55 text-xs leading-relaxed mt-2 italic">
          claude.ai (web, easiest) or Claude Code if you've already got it.
        </p>
      </li>
      <li class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <div class="flex items-baseline gap-3 mb-2">
          <span class="font-extrabold text-claude-orange text-2xl">٢ · 2</span>
          <div>
            <h3 dir="rtl" class="font-cairo font-bold text-lg text-right">الصق الوصفة</h3>
            <h3 class="font-semibold text-base text-ink/70">Paste the recipe</h3>
          </div>
        </div>
        <p dir="rtl" class="font-cairo text-ink/75 text-sm leading-relaxed text-right mt-2">
          اضغط الزر البرتقالي فوق، والصق الوصفة كاملة في محادثة جديدة في كلود.
        </p>
        <p class="text-ink/55 text-xs leading-relaxed mt-2 italic">
          Hit the orange button above, then paste the entire thing into a new Claude chat.
        </p>
      </li>
      <li class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <div class="flex items-baseline gap-3 mb-2">
          <span class="font-extrabold text-claude-orange text-2xl">٣ · 3</span>
          <div>
            <h3 dir="rtl" class="font-cairo font-bold text-lg text-right">جاوب على ٤ أسئلة</h3>
            <h3 class="font-semibold text-base text-ink/70">Answer 4 quick questions</h3>
          </div>
        </div>
        <p dir="rtl" class="font-cairo text-ink/75 text-sm leading-relaxed text-right mt-2">
          اسم شغلك، الأسئلة اللي يكررها العملاء، شنو الملفات اللي عندك، وأكشن واحد تبي البوت يسوّيه.
        </p>
        <p class="text-ink/55 text-xs leading-relaxed mt-2 italic">
          Business name, the repetitive customer questions, what docs you have, and one action your bot should be able to do.
        </p>
      </li>
      <li class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <div class="flex items-baseline gap-3 mb-2">
          <span class="font-extrabold text-claude-orange text-2xl">٤ · 4</span>
          <div>
            <h3 dir="rtl" class="font-cairo font-bold text-lg text-right">اتبع الخطوات</h3>
            <h3 class="font-semibold text-base text-ink/70">Follow the setup</h3>
          </div>
        </div>
        <p dir="rtl" class="font-cairo text-ink/75 text-sm leading-relaxed text-right mt-2">
          كلود يكتب الكود كامل ويخطّيك خطوة خطوة. شات بوت شغّال بـ١٥ دقيقة تقريباً.
        </p>
        <p class="text-ink/55 text-xs leading-relaxed mt-2 italic">
          Claude writes the full code + step-by-step setup. Running chatbot in ~15 minutes.
        </p>
      </li>
    </ol>
  </section>

  <!-- ── What you get ── -->
  <section class="mx-auto max-w-4xl px-5 sm:px-8 pb-16">
    <div class="mb-6 flex items-baseline justify-between flex-wrap gap-2">
      <h2 dir="rtl" class="font-cairo text-2xl font-bold text-ink">اللي بيوصلك في النهاية</h2>
      <span class="text-sm uppercase tracking-[0.18em] font-semibold text-ink/40">What you'll have</span>
    </div>

    <div class="grid sm:grid-cols-3 gap-4">
      <div class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <h3 class="font-semibold text-lg text-claude-orange">OpenRouter</h3>
        <p dir="rtl" class="font-cairo mt-2 text-ink/75 text-sm leading-relaxed text-right">
          مفتاح واحد، كل المودلات — Claude, GPT, Gemini, Llama. كريدت مجاني للبداية. ما تنحبس بمزوّد.
        </p>
        <p class="mt-2 text-ink/55 text-xs leading-relaxed italic">
          One API key, every major model — Claude, GPT, Gemini, Llama. Free credits to start. Never locked in.
        </p>
      </div>
      <div class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <h3 class="font-semibold text-lg text-claude-orange">RAG</h3>
        <p dir="rtl" class="font-cairo mt-2 text-ink/75 text-sm leading-relaxed text-right">
          البوت يقرأ <em>ملفاتك</em> — PDF, Word, markdown — ويجاوب منها.
        </p>
        <p class="mt-2 text-ink/55 text-xs leading-relaxed italic">
          The bot reads <em>your</em> documents — PDFs, Word, markdown, plain text — and answers from them.
        </p>
      </div>
      <div class="bg-paper/40 border border-ink/5 rounded-xl p-5">
        <h3 class="font-semibold text-lg text-claude-orange">Tool Calling</h3>
        <p dir="rtl" class="font-cairo mt-2 text-ink/75 text-sm leading-relaxed text-right">
          البوت <em>يسوّي</em> أشياء — يحجز، يحوّل، يدزّ، يدوّر. مو بس كلام.
        </p>
        <p class="mt-2 text-ink/55 text-xs leading-relaxed italic">
          The bot can <em>do</em> things — book, transfer, send, look up. Not just talk.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Bottom CTA ── -->
  <section class="mx-auto max-w-4xl px-5 sm:px-8 pb-20">
    <div class="bg-ink text-cream rounded-2xl p-8 sm:p-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <div>
        <p class="text-cream/60 text-xs uppercase tracking-[0.18em] font-semibold">جاهز؟ · Ready?</p>
        <p dir="rtl" class="font-cairo mt-3 text-2xl sm:text-3xl font-bold tracking-tight text-right">
          انسخ الوصفة، الصقها في كلود، اطلقه.
        </p>
        <p class="mt-1 text-xl sm:text-2xl font-semibold tracking-tight text-cream/80">
          Copy the recipe, paste into Claude, ship.
        </p>
      </div>
      <button
        id="copy-btn-bottom"
        class="inline-flex items-center justify-center gap-3 bg-claude-orange text-cream px-7 py-4 rounded-full font-semibold text-base hover:bg-cream hover:text-ink transition-colors cursor-pointer whitespace-nowrap shrink-0"
        aria-label="Copy the recipe / انسخ الوصفة"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        انسخ · Copy
      </button>
    </div>
  </section>

  <!-- ── The recipe content (embedded raw for the copy script) ── -->
  <script id="recipe-payload" type="text/plain" set:html={recipeRaw}></script>

  <script is:inline>
    (function () {
      const payload = document.getElementById('recipe-payload')?.textContent ?? '';

      async function copyRecipe(btn) {
        try {
          await navigator.clipboard.writeText(payload);
          flashSuccess(btn);
        } catch (err) {
          const ta = document.createElement('textarea');
          ta.value = payload;
          ta.style.position = 'fixed';
          ta.style.left = '-1000px';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          try {
            document.execCommand('copy');
            flashSuccess(btn);
          } catch {
            alert("Couldn't copy automatically — please select the recipe text manually.");
          } finally {
            document.body.removeChild(ta);
          }
        }
      }

      function flashSuccess(btn) {
        const copyIcon = btn.querySelector('.copy-icon');
        const checkIcon = btn.querySelector('.check-icon');
        const label = btn.querySelector('.copy-label') ?? btn.querySelector('span');
        const originalText = label?.textContent ?? 'Copy the recipe';

        if (copyIcon && checkIcon) {
          copyIcon.classList.add('hidden');
          checkIcon.classList.remove('hidden');
        }
        if (label) label.textContent = 'تم النسخ — الصق في كلود · Copied — paste into Claude';

        setTimeout(() => {
          if (copyIcon && checkIcon) {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
          }
          if (label) label.textContent = originalText;
        }, 2400);
      }

      document.getElementById('copy-btn')?.addEventListener('click', (e) => copyRecipe(e.currentTarget));
      document.getElementById('copy-btn-bottom')?.addEventListener('click', (e) => copyRecipe(e.currentTarget));
    })();
  </script>
</Layout>
